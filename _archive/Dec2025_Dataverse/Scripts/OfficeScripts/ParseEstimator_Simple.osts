{"version":"0.3.0","body":"function main(workbook: ExcelScript.Workbook): object {\n  const scopes: { scopeName: string; totalHours: number; totalAmount: number }[] = [];\n  const sheets = workbook.getWorksheets();\n\n  for (const sheet of sheets) {\n    const sheetName = sheet.getName();\n\n    // Only process scope sheets\n    if (!sheetName.includes(\"NETA\") && !sheetName.includes(\"PSS\") &&\n      !sheetName.includes(\"ATS\") && !sheetName.includes(\"Scope\")) {\n      continue;\n    }\n\n    // Get totals from fixed cells\n    const totalHours = Number(sheet.getRange(\"J3\").getValue()) || 0;\n    const totalAmount = Number(sheet.getRange(\"P3\").getValue()) || 0;\n\n    if (totalHours > 0) {\n      scopes.push({\n        scopeName: sheetName,\n        totalHours: totalHours,\n        totalAmount: totalAmount\n      });\n    }\n  }\n\n  return {\n    scopes: scopes,\n    extractedAt: new Date().toISOString(),\n    sourceFile: workbook.getName()\n  };\n}\n","description":"Simple scope extractor for testing","noCodeMetadata":"","parameterInfo":"{\"version\":1,\"originalParameterOrder\":[],\"parameterSchema\":{\"type\":\"object\",\"default\":{},\"x-ms-visibility\":\"internal\"},\"returnSchema\":{\"type\":\"object\",\"properties\":{\"result\":{\"type\":\"object\"}}},\"signature\":{\"comment\":\"\",\"parameters\":[{\"name\":\"workbook\",\"comment\":\"\"}]}}","apiInfo":"{\"variant\":\"synchronous\",\"variantVersion\":2}"}