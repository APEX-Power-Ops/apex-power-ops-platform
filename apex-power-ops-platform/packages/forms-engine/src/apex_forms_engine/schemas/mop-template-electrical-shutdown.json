        "notes": "Add additional steps as needed for specific work scope"
      },
      {
        "stepNumber": 9,
        "phase": "Verification",
        "procedure": "Perform post-work verification. Confirm all work complete, no tools or debris in equipment.",
        "expectedResult": "Work area clean, all connections verified, panels closed",
        "responsibleParty": "Crew Lead",
        "estimatedDuration": "15 min",
        "riskLevel": "Low",
        "isHoldPoint": true
      },
      {
        "stepNumber": 10,
        "phase": "Restoration",
        "procedure": "Remove Temporary Protective Grounds in reverse order of installation (line-end first, ground-end last).",
        "expectedResult": "All TPGs removed and accounted for",
        "responsibleParty": "Qualified Technician",
        "estimatedDuration": "15 min",
        "riskLevel": "Medium",
        "isHoldPoint": false,
        "sopReference": "SOP-GRD-001"
      },
      {
        "stepNumber": 11,
        "phase": "Restoration",
        "procedure": "Notify System Operator / Control Room of readiness to restore. Obtain authorization to remove LOTO.",
        "expectedResult": "Verbal authorization received",
        "responsibleParty": "Crew Lead",
        "estimatedDuration": "10 min",
        "riskLevel": "Low",
        "isHoldPoint": true
      },
      {
        "stepNumber": 12,
        "phase": "Restoration",
        "procedure": "Remove all LOTO devices. Verify all personnel locks removed.",
        "expectedResult": "All locks and tags removed",
        "responsibleParty": "All Crew",
        "estimatedDuration": "10 min",
        "riskLevel": "Medium",
        "isHoldPoint": false
      },
      {
        "stepNumber": 13,
        "phase": "Restoration",
        "procedure": "Perform restoration switching per approved switching order. Close disconnects, rack in breakers as required.",
        "expectedResult": "Equipment restored to service",
        "responsibleParty": "Switching Authority / Crew Lead",
        "estimatedDuration": "30 min",
        "riskLevel": "High",
        "isHoldPoint": false
      },
      {
        "stepNumber": 14,
        "phase": "Restoration",
        "procedure": "Verify equipment energized and operating normally. Check for alarms, abnormal indications.",
        "expectedResult": "No alarms, normal operation confirmed",
        "responsibleParty": "Crew Lead",
        "estimatedDuration": "15 min",
        "riskLevel": "Medium",
        "isHoldPoint": false
      },
      {
        "stepNumber": 15,
        "phase": "Closeout",
        "procedure": "Notify System Operator / Control Room of work complete. Release clearance.",
        "expectedResult": "Clearance released, documented",
        "responsibleParty": "Crew Lead",
        "estimatedDuration": "10 min",
        "riskLevel": "Low",
        "isHoldPoint": false
