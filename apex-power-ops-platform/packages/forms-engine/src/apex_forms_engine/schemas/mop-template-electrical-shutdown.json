  "workScript": {
    "estimatedDuration": "",
    "actualDuration": "",
    "steps": [
      {
        "stepNumber": 1,
        "phase": "Pre-Work",
        "procedure": "Conduct safety briefing with all personnel. Review MOP, hazards, PPE requirements, and emergency procedures.",
        "expectedResult": "All crew members understand scope, hazards, and procedures",
        "responsibleParty": "Crew Lead",
        "estimatedDuration": "15 min",
