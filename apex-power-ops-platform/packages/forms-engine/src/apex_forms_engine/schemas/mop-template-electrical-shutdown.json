        "phase": "Pre-Work",
        "procedure": "Verify all required approvals, permits, and clearances are in place.",
        "expectedResult": "All approvals documented and valid",
        "responsibleParty": "Crew Lead",
        "estimatedDuration": "10 min",
        "riskLevel": "Low",
        "isHoldPoint": true,
        "notes": "Cannot proceed without valid clearance"
      },
      {
        "stepNumber": 3,
        "phase": "Pre-Work",
        "procedure": "Contact System Operator / Control Room. Confirm readiness to proceed.",
        "expectedResult": "Verbal confirmation received, clearance number documented",
        "responsibleParty": "Crew Lead",
        "estimatedDuration": "10 min",
        "riskLevel": "Low",
        "isHoldPoint": true,
        "notes": "Document clearance number and operator name"
      },
      {
        "stepNumber": 4,
        "phase": "Isolation",
        "procedure": "Perform switching/isolation per approved switching order. Open disconnects, rack out breakers as required.",
        "expectedResult": "Equipment isolated at all identified points",
        "responsibleParty": "Switching Authority / Crew Lead",
        "estimatedDuration": "30 min",
        "riskLevel": "High",
        "isHoldPoint": false,
        "sopReference": "SOP-ISO-001"
      },
      {
        "stepNumber": 5,
        "phase": "Isolation",
        "procedure": "Apply LOTO devices at all isolation points. Verify all personnel locks applied.",
        "expectedResult": "All isolation points locked and tagged",
        "responsibleParty": "All Crew",
        "estimatedDuration": "15 min",
        "riskLevel": "Medium",
        "isHoldPoint": false
      },
      {
        "stepNumber": 6,
        "phase": "Isolation",
        "procedure": "Perform voltage absence verification using three-point method: (1) Test known live, (2) Test work location, (3) Re-test known live.",
        "expectedResult": "Zero voltage confirmed at all phases to ground and phase-to-phase",
        "responsibleParty": "Qualified Technician",
        "estimatedDuration": "15 min",
        "riskLevel": "High",
        "isHoldPoint": true,
        "formReference": "IVF-001",
        "notes": "CRITICAL: Do not proceed if any voltage present"
      },
      {
        "stepNumber": 7,
        "phase": "Isolation",
        "procedure": "Install Temporary Protective Grounds (TPG) if required per SOP-GRD-001.",
        "expectedResult": "Grounds installed and verified. Equipotential zone established.",
        "responsibleParty": "Qualified Technician",
        "estimatedDuration": "20 min",
        "riskLevel": "Medium",
        "isHoldPoint": false,
        "sopReference": "SOP-GRD-001",
        "formReference": "IVF-001"
      },
      {
        "stepNumber": 8,
        "phase": "Execution",
        "procedure": "[WORK SCOPE - Define specific tasks to be performed]",
        "expectedResult": "[Define expected outcome]",
        "responsibleParty": "",
        "estimatedDuration": "",
        "riskLevel": "Medium",
