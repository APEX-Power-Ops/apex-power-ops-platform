    {
      "label": "Run platform API local",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-Command",
        "$repoRoot = (Resolve-Path (Join-Path '${workspaceFolder}' '..')).Path; $script = Join-Path $repoRoot 'apps/control-plane-api/scripts/run_platform_api_local.ps1'; if (-not (Test-Path $script)) { throw 'apps/control-plane-api is not present under the parent repo root for this bootstrap packet.' }; Set-Location $repoRoot; & $script"
      ],
      "options": {
        "cwd": "${workspaceFolder}\\..",
        "env": {
          "APEX_PLATFORM_PYTHON": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
          "PYTHONPATH": "packages/calc-engine/src"
        }
      },
      "isBackground": true,
      "problemMatcher": [],
      "group": "build"
    },
