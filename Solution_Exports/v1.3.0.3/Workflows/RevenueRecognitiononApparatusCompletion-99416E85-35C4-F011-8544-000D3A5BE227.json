          "metadata": {
            "operationMetadataId": "6e2393ab-a91a-4079-b63b-6c73f5f75ee6"
          },
          "type": "OpenApiConnectionWebhook",
          "inputs": {
            "host": {
              "connectionName": "shared_commondataserviceforapps",
              "operationId": "SubscribeWebhookTrigger",
              "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps"
            },
            "parameters": {
              "subscriptionRequest/message": 3,
              "subscriptionRequest/entityname": "cr950_apparatus",
              "subscriptionRequest/scope": 4,
              "subscriptionRequest/filteringattributes": "cr950_completion_status",
              "subscriptionRequest/filterexpression": "cr950_completion_status eq 2"
            },
            "authentication": "@parameters('$authentication')"
          }
        }
      },
      "actions": {
        "Condition_-_Check_Date_Completed": {
          "actions": {
            "Update_Date_Completed": {
              "runAfter": {},
              "metadata": {
                "operationMetadataId": "eabc2c84-3628-4910-a8e8-b091ebc6547b"
              },
              "type": "OpenApiConnection",
              "inputs": {
                "host": {
                  "connectionName": "shared_commondataserviceforapps",
                  "operationId": "UpdateOnlyRecordWithOrganization",
                  "apiId": "/providers/Microsoft.PowerApps/apis/shared_commondataserviceforapps"
                },
                "parameters": {
                  "organization": "https://orgf05a3756.crm.dynamics.com",
                  "entityName": "cr950_apparatuses",
                  "recordId": "@triggerOutputs()?['body/cr950_apparatusid']",
                  "item/cr950_datecompleted": "@utcNow()"
                },
                "authentication": "@parameters('$authentication')"
              }
            }
          },
          "runAfter": {},
          "expression": {
            "not": {
              "contains": [
                "@triggerOutputs()?['body/cr950_datecompleted']",
