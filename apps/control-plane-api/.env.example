# Apex platform control-plane and calculation runtime configuration

# Required runtime database URL
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Optional direct connection for admin-only operations
# DATABASE_URL_DIRECT=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Optional local source database used by migration utilities
DATABASE_URL_LOCAL=postgresql://postgres:[local-password]@localhost:5432/tcc_v5
SOURCE_DATABASE_URL=postgresql://postgres:[local-password]@localhost:5432/tcc_v5

SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWKS_URL=https://[project-ref].supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_EMAIL_REDIRECT_URL=http://localhost:8000/demo/neta-tcc

# Optional public MCP/OAuth discovery surface for the governed MCP host.
# These should remain unset until a real public deployment target exists.
# See MCP_OAUTH_PLATFORM_SETTINGS.md for the current Supabase-backed values,
# ChatGPT connector requirements, and the Auth0 target mapping.
PUBLIC_MCP_BASE_URL=
PUBLIC_OAUTH_AUTHORIZATION_URL=
PUBLIC_OAUTH_TOKEN_URL=
PUBLIC_OAUTH_JWKS_URL=
PUBLIC_OAUTH_REGISTRATION_URL=
PUBLIC_OAUTH_ISSUER=
PUBLIC_OAUTH_AUDIENCE=
PUBLIC_OAUTH_CLIENT_ID=
PUBLIC_OAUTH_REDIRECT_URIS=[]
PUBLIC_OAUTH_SCOPES=openid profile email

# Optional dedicated public OAuth/MCP discovery surface for the Supabase platform connector.
# These stay unset until a separate Supabase MCP audience and host are provisioned.
SUPABASE_MCP_PUBLIC_BASE_URL=
SUPABASE_MCP_OAUTH_AUTHORIZATION_URL=
SUPABASE_MCP_OAUTH_TOKEN_URL=
SUPABASE_MCP_OAUTH_JWKS_URL=
SUPABASE_MCP_OAUTH_REGISTRATION_URL=
SUPABASE_MCP_OAUTH_ISSUER=
SUPABASE_MCP_OAUTH_AUDIENCE=
SUPABASE_MCP_OAUTH_CLIENT_ID=
SUPABASE_MCP_OAUTH_REDIRECT_URIS=[]
SUPABASE_MCP_OAUTH_SCOPES=openid profile email supabase.read supabase.write supabase.admin
SUPABASE_MCP_OAUTH_USERINFO_URL=
SUPABASE_ALLOWED_PROJECTS_JSON=[]
SUPABASE_MANAGEMENT_API_URL=https://api.supabase.com/v1
SUPABASE_MANAGEMENT_TOKEN=
SUPABASE_MANAGEMENT_TIMEOUT_SECONDS=30
SUPABASE_ALLOWED_MIGRATION_ROOTS=supabase/migrations,migrations
SUPABASE_ALLOWED_FUNCTION_ROOTS=
SUPABASE_ENABLE_MIGRATION_APPLY=false
SUPABASE_ENABLE_EDGE_FUNCTION_DEPLOY=false
SUPABASE_CLI_PROJECT_DIR=
SUPABASE_CLI_PATH=supabase
SUPABASE_CLI_TIMEOUT_SECONDS=600
SUPABASE_ACCESS_TOKEN=

# Optional dedicated public OAuth/MCP discovery surface for the GitHub repository connector.
# These stay unset until a separate GitHub MCP audience and host are provisioned.
GITHUB_MCP_PUBLIC_BASE_URL=
GITHUB_MCP_OAUTH_AUTHORIZATION_URL=
GITHUB_MCP_OAUTH_TOKEN_URL=
GITHUB_MCP_OAUTH_JWKS_URL=
GITHUB_MCP_OAUTH_REGISTRATION_URL=
GITHUB_MCP_OAUTH_ISSUER=
GITHUB_MCP_OAUTH_AUDIENCE=
GITHUB_MCP_OAUTH_CLIENT_ID=
GITHUB_MCP_OAUTH_REDIRECT_URIS=[]
GITHUB_MCP_OAUTH_SCOPES=openid profile email github.read github.write github.actions
GITHUB_MCP_OAUTH_USERINFO_URL=
GITHUB_ALLOWED_REPOS_JSON=[]
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_IDS_JSON={}
GITHUB_ALLOWED_WORKFLOW_DISPATCHES_JSON={}
GITHUB_COPILOT_REVIEWERS_JSON={}

ENABLE_LOCAL_TEST_AUTH=false
LOCAL_TEST_AUTH_SECRET=change-me-for-shared-dev-environments-min-32-chars
LOCAL_TEST_AUTH_USERS_JSON=[{"email":"neta-test-a@example.com","user_id":"11111111-1111-1111-1111-111111111111","label":"Local Test User A"},{"email":"neta-test-b@example.com","user_id":"22222222-2222-2222-2222-222222222222","label":"Local Test User B"}]

# Optional short-lived operator token exchange for direct MCP access without interactive OAuth.
# Configure both secrets to enable POST /api/v1/auth/operator-token.
OPERATOR_BOOTSTRAP_TOKEN=
OPERATOR_TOKEN_SIGNING_SECRET=
OPERATOR_TOKEN_EMAIL=operator-direct@apexpowerops.com
OPERATOR_TOKEN_LABEL=Operator Direct Access
OPERATOR_TOKEN_USER_ID=
OPERATOR_TOKEN_TTL_MINUTES=15

PG_HOST=aws-0-[region].pooler.supabase.com
PG_PORT=6543
PG_DATABASE=postgres
PG_USER=postgres.[project-ref]
PG_PASSWORD=[password]

APP_ENV=development
LOG_LEVEL=INFO